# activia-trace — Backend Configuration
# Copy this file to .env and fill in real values (never commit secrets).

# PostgreSQL connection string (async with asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/trace

# Secret key for JWT signing — minimum 32 characters
SECRET_KEY=change-me-to-a-secret-key-at-least-32-chars

# AES-256 encryption key for PII at rest — exactly 32 characters
ENCRYPTION_KEY=change-me-32-char-encryption-key

# Access token expiration in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token expiration in days (default: 30)
REFRESH_TOKEN_EXPIRE_DAYS=30

# Debug mode — controls recovery token exposure in responses (default: false)
DEBUG=false

# Test database URL (used by pytest)
TEST_DATABASE_URL=postgresql+asyncpg://test:test@localhost:5433/test_trace
